# sealed-pane.env — source this in a cmux pane before launching an agent, to (a) route the agent's
# grunt work to a local sealed HEARTH and (b) silence cmux's own telemetry (C0 findings).
# Full sealed enforcement (signed-out, OS-level egress containment) is the C3 launcher's job; this
# file is the per-pane offload + telemetry-off recipe. Usage:  `source examples/cmux/sealed-pane.env`
#
# See docs/cmux/RUNBOOK_wiring.md and docs/cmux/AUDIT.md §4.

# --- HEARTH offload for OpenAI-shaped agents (codex / opencode / any OpenAI SDK) ---------------
# Point the agent's OpenAI client at the local HEARTH gateway. Start it first with a sealed serve:
#   HEARTH_ROUTING_YAML=config/routing.private.yaml HEARTH_HOST=127.0.0.1 HEARTH_BACKEND=mlx \
#   HF_HUB_OFFLINE=1 TRANSFORMERS_OFFLINE=1 uv run hearth serve
export OPENAI_BASE_URL="http://127.0.0.1:8080/v1"
export OPENAI_API_KEY="$(cat "$HOME/.hearth/token" 2>/dev/null)"

# --- cmux telemetry off (C0 AUDIT §3 A4; the CLI Sentry gate is env-only) ----------------------
export CMUX_CLI_SENTRY_DISABLED=1
export CMUX_CLAUDE_HOOK_SENTRY_DISABLED=1
# Reminder (not env-settable here): the macOS app's PostHog/Sentry need `sendAnonymousTelemetry=false`
# in defaults BEFORE launch, and Sparkle auto-update must be off — the C3 launcher enforces these.
